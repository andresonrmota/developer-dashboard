// Regras de Segurança do Firestore para Developer Dashboard
// Copie este conteúdo no Console do Firebase:
// Firebase Console → Firestore Database → Rules
//
// IMPORTANTE: Substitua SEU_UID_AQUI pelo UID real do seu
// usuário Google (visível no console do navegador após o primeiro login)

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{project} {
      // Leitura: pública (qualquer pessoa pode visualizar)
      allow read: if true;

      // Escrita: apenas o owner autenticado
      allow write: if request.auth != null
                   && request.auth.uid == 'O805TXABLZeD2ns3u1jwTPAj2a33';
    }

    // Bloqueia acesso a qualquer outra coleção
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
